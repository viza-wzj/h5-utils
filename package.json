{
  "name": "h5-utils-monorepo",
  "private": true,
  "description": "H5 工具库 Monorepo",
  "scripts": {
    "build": "pnpm --filter @i17hush/h5-utils run build",
    "dev": "node scripts/dev.mjs",
    "dev:weapp": "node scripts/dev.mjs weapp",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "test": "pnpm --filter @i17hush/h5-utils run test",
    "typecheck": "pnpm --filter @i17hush/h5-utils run typecheck",
    "merge": "node scripts/merge.mjs",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major",
    "setup": "cd apps/taro-app && pnpm install"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.5.0"
  }
}
